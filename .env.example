# ── Database (use Supabase pooler port 6543 for serverless) ──
# Example: postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/coded_chapter

# ── Supabase Auth ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-signing-secret

# Frontend (baked in at build time — set in Vercel before deploy)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Admin (only this email can publish posts) ──
ADMIN_EMAIL=admin@example.com
VITE_ADMIN_EMAIL=admin@example.com

# ── Upstash Redis (required for heavy traffic rate limiting) ──
# Free tier works fine to start: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Deploy ──
FRONTEND_URL=https://your-domain.vercel.app
PORT=5000
